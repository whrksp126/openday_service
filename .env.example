# ── MySQL (컨테이너 초기화 및 앱 접속 공통) ──────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=openday
MYSQL_USER=openday_user
MYSQL_PASSWORD=openday_password

# ── App DB 접속 (MYSQL_HOST는 docker-compose service 명과 일치) ──────────────
MYSQL_HOST=mysql
MYSQL_PORT=3306

# ── 네이버 지오코딩 API ────────────────────────────────────────────────────────
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# ── Flask ───────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here
BCRYPT_LEVEL=10
FLASK_ENV=production
